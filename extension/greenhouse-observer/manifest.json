{
  "manifest_version": 3,
  "name": "Greenhouse Observer",
  "version": "0.1.0",
  "description": "Observe manual Greenhouse applications and send session traces to a local backend.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "http://127.0.0.1:8776/*",
    "http://localhost:8776/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Greenhouse Observer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
