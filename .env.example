# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_USE_TLS=true

# Alert recipients
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com

# My Greenhouse authentication (for source: my_greenhouse)
GREENHOUSE_EMAIL=your_my_greenhouse_email@gmail.com
GREENHOUSE_PASSWORD=your_my_greenhouse_password
MY_GREENHOUSE_STORAGE_STATE=.local/my_greenhouse_storage_state.json
MY_GREENHOUSE_HEADLESS=true
MY_GREENHOUSE_LOGIN_HEADLESS=false
# Optional: load additional result pages from "See more jobs".
# MY_GREENHOUSE_LOAD_MORE_PAGES=60

# Playwright adapters (default is headless; set false for headed)
PW_HEADLESS=true
META_HEADLESS=true

# React dashboard URL used by backend redirects for /, /monitor, /jobs, and /mail.
FRONTEND_BASE_URL=http://127.0.0.1:5173
# Optional defaults for recurring crawling (can be changed live in Monitor UI).
CRAWL_SCHEDULE_ENABLED=false
CRAWL_SCHEDULE_INTERVAL_MINUTES=60

# Mailbox monitoring (Gmail only) using the Gmail API.
MAIL_DB_ENABLED=true
# Optional DB file override (default: alongside state file as mail.db).
# MAIL_DB_PATH=.state/mail.db
MAIL_SCHEDULE_ENABLED=false
MAIL_POLL_INTERVAL_MINUTES=10
MAIL_BACKFILL_DAYS=7
MAIL_SYNC_MAX_MESSAGES=100
MAIL_DB_BUSY_TIMEOUT_MS=5000

# Gmail OAuth (Google Cloud desktop/installed-app client).
# You can either copy the ID/secret below or point GOOGLE_OAUTH_CLIENT_JSON
# at the downloaded client_secret_*.json file from Google Cloud.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_JSON=

# Optional local SLM review for ambiguous job-related mail.
MAIL_SLM_ENABLED=true
MAIL_SLM_URL=http://127.0.0.1:11434/api/chat
MAIL_SLM_MODEL=qwen2.5:3b
MAIL_SLM_TIMEOUT_SECONDS=20

# Keep only US-based openings across all sources (default behavior is true).
US_ONLY_JOBS=true
# Optional custom regex for matching US roles in title/location/url.
# US_ONLY_REGEX=(?i)\\b(?:united states|usa|u\\.s\\.|remote[^\\n]{0,12}us)\\b

# Keep only target profile roles after scraping (full stack/cloud/AI-ML/data,
# early career through software engineer I/II/III).
RELEVANCE_FILTER=true
# Optional multi-resume profile config for resume-aware job ranking.
RESUME_PROFILES_FILE=.local/resume_profiles.yaml
# Keep only jobs posted today.
POSTED_TODAY_ONLY=false
# Default recency window is the last 7 days when a parseable posted date exists.
# Set 0=today only, 1=today+yesterday, -1=disable posted-date gate.
# MAX_POSTED_AGE_DAYS=7
# Allow jobs with missing or unparseable posted_at to pass the recency gate.
ALLOW_UNKNOWN_POSTED_AT=true
# Optional force include / exclude patterns over combined title/team/description/url.
# RELEVANCE_INCLUDE_REGEX=(?i)\\b(full[ -]?stack|cloud|ai|ml|data analyst|software engineer\\s*(i|ii|iii|1|2|3))\\b
# RELEVANCE_EXCLUDE_REGEX=(?i)\\b(senior|staff|principal|manager|director)\\b

# Optional company-level E-Verify enrichment for jobs dashboard badges/filters.
EVERIFY_RESOLUTION_ENABLED=true
EVERIFY_REFRESH_DAYS=21
EVERIFY_UNKNOWN_RETRY_HOURS=72
# Optional manual overrides file (.json or .csv with company,status,note,source).
# EVERIFY_OVERRIDES_FILE=.state/everify_overrides.json
# Optional background resolver command (receives EVERIFY_COMPANY env var and returns JSON {"status":"enrolled|not_found|not_enrolled|unknown","source":"...","note":"..."}).
# EVERIFY_RESOLVER_CMD=
EVERIFY_RESOLVER_TIMEOUT_SECONDS=20
# Optional cache path (default: alongside state file as everify_cache.json).
# EVERIFY_CACHE_PATH=.state/everify_cache.json

# Structured jobs DB (SQLite, enabled by default).
JOBS_DB_ENABLED=true
# Optional DB file override (default: alongside state file as jobs.db).
# JOBS_DB_PATH=.state/jobs.db
# Keep high-volume per-run observation data for this many days.
JOBS_DB_OBSERVATION_RETENTION_DAYS=4
# Keep per-company run outcome rows for this many days.
JOBS_DB_RUN_RETENTION_DAYS=4
# Keep inactive jobs for this many days before deletion.
JOBS_DB_INACTIVE_RETENTION_DAYS=120
# Keep compact daily aggregate stats for this many days.
JOBS_DB_DAILY_STATS_RETENTION_DAYS=365
# Keep persisted SLM score cache rows for this many days (by last use).
JOBS_DB_SLM_SCORE_RETENTION_DAYS=90

# Verify extracted job URLs on every monitor run (default true).
VERIFY_JOB_URLS=true
# Concurrent URL checks per run.
VERIFY_JOB_URLS_WORKERS=8
# Per-URL HTTP timeout for verification.
VERIFY_JOB_URLS_TIMEOUT_SECONDS=25
# Max unique job URLs verified each run (0 = no limit).
VERIFY_JOB_URLS_MAX_URLS=500
# Optional override output path for TSV artifact.
# VERIFY_JOB_URLS_OUTPUT_PATH=.state/last_run_report_url_verification.tsv

# Optional policy hook (stdin JSON -> {"plan":[...]}).
# Example: uv run python scripts/policy_router.py
ORCHESTRATOR_POLICY_CMD=

# Optional experimental SLM router (local Ollama). Deterministic adaptive routing
# is the default and recommended path; enable this only for real multi-source experiments.
ORCHESTRATOR_SLM_EXPERIMENTAL=false
ORCHESTRATOR_SLM_PROVIDER=
ORCHESTRATOR_SLM_URL=http://127.0.0.1:11434/api/chat
ORCHESTRATOR_SLM_MODEL=phi4-mini:latest
ORCHESTRATOR_SLM_TIMEOUT_SECONDS=8

# Optional SLM job scoring for /api/jobs match ranking (uses quantized local model).
SLM_SCORING=false
SLM_SCORING_PROVIDER=ollama
SLM_SCORING_URL=http://127.0.0.1:11434/api/chat
SLM_SCORING_MODEL=qwen2.5:3b
SLM_ROLE_MODEL=ministral-3:3b
SLM_INTERNSHIP_MODEL=qwen2.5:3b
# Optional jobs-page compare list. The first request still defaults to SLM_SCORING_MODEL.
SLM_SCORING_COMPARE_MODELS=qwen2.5:3b,ministral-3:3b
SLM_SCORING_TIMEOUT_SECONDS=25
# Limit number of jobs scored per /api/jobs request to keep UI responsive.
SLM_SCORING_MAX_JOBS=12
# Parallel SLM requests per /api/jobs request.
SLM_SCORING_WORKERS=1
# When true, SLM scoring runs only for sort=best_match (recommended).
SLM_SCORING_ONLY_BEST_MATCH=true
# When true, also rerank deterministic in-scope jobs; otherwise only ambiguous jobs hit the SLM.
SLM_SCORING_RERANK_TOP_MATCHES=false
# When true, precompute SLM scores at dashboard startup and after each monitor run.
SLM_SCORING_PRECOMPUTE_ON_RUN=true
# Persist SLM score cache in SQLite so the same job description is not rescored after restart.
SLM_SCORING_PERSIST_CACHE=true
# Optional debug logs for SLM scoring apply/fallback decisions.
# SLM_SCORING_DEBUG=true
